# Base URL of the NestJS backend API
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Request timeout in milliseconds
NUXT_PUBLIC_API_TIMEOUT=15000

# When true (default), all API calls resolve against in-memory mock data
# instead of hitting the network. Set to false once the backend is live.
NUXT_PUBLIC_USE_MOCK_API=true

# Simulated network latency (ms) for mock API calls, so loading states are visible
NUXT_PUBLIC_MOCK_DELAY=350
